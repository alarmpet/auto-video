{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-video/schemas/yadam/tts-scene-request.schema.json/v1",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "jobId": { "type": "string" },
    "sceneId": { "type": "string" },
    "segmentId": { "type": "string" },
    "order": { "type": "integer", "minimum": 1 },
    "sourceHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "ttsNormalizedHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "ttsOptionsHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "idempotencyKey": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "text": { "type": "string" },
    "provider": { "type": "string" },
    "adapterVersion": { "type": "string" },
    "model": { "type": "string" },
    "voice": { "type": "string" },
    "language": { "type": "string" },
    "speed": { "type": "number", "exclusiveMinimum": 0 },
    "totalStep": { "type": "integer", "exclusiveMinimum": 0 },
    "silenceSeconds": { "type": "number", "minimum": 0 },
    "readSlow": { "type": "boolean" },
    "continuousNext": { "type": "boolean" }
  },
  "required": [
    "schemaVersion", "jobId", "sceneId", "segmentId", "order", "sourceHash",
    "ttsNormalizedHash", "ttsOptionsHash", "idempotencyKey", "text",
    "provider", "adapterVersion", "model", "voice", "language", "speed",
    "totalStep", "silenceSeconds", "readSlow", "continuousNext"
  ],
  "additionalProperties": false
}
