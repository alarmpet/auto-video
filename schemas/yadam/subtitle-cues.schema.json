{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-video.local/schemas/yadam/subtitle-cues.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "cueId",
      "segmentId",
      "sceneIds",
      "startSeconds",
      "endSeconds",
      "durationSeconds",
      "text",
      "sourceHashes"
    ],
    "properties": {
      "cueId": { "type": "string" },
      "segmentId": { "type": "string" },
      "sceneIds": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string" }
      },
      "startSeconds": { "type": "number", "minimum": 0 },
      "endSeconds": { "type": "number", "minimum": 0 },
      "durationSeconds": { "type": "number", "exclusiveMinimum": 0 },
      "text": { "type": "string", "minLength": 1 },
      "sourceHashes": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
