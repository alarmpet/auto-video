{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-video.local/schemas/yadam/segment-qa-report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reportType",
    "segmentId",
    "qualityOk",
    "finalVerdict",
    "checks",
    "failures",
    "warnings",
    "artifactHashes",
    "measuredDurationSeconds"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "reportType": { "const": "segment_qa" },
    "segmentId": { "type": "string" },
    "qualityOk": { "type": "boolean" },
    "finalVerdict": { "enum": ["pass", "fail"] },
    "checks": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "actual", "limit"],
        "properties": {
          "status": { "enum": ["pass", "fail"] },
          "actual": {},
          "limit": {}
        }
      }
    },
    "failures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifactHashes": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
    },
    "measuredDurationSeconds": { "type": "number", "minimum": 0 },
    "acknowledgedNotices": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
