{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-video/schemas/yadam/qa-report.schema.json/v1",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "jobId": { "type": "string" },
    "stageId": { "type": "string" },
    "inputHash": { "type": "string" },
    "gateStatus": { "type": "string", "enum": ["pass", "warning", "fail"] },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "passed": { "type": "boolean" },
          "violations": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["name", "passed", "violations"],
        "additionalProperties": false
      }
    }
  },
  "required": ["schemaVersion", "jobId", "stageId", "inputHash", "gateStatus", "checks"],
  "additionalProperties": false
}
