{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-video.local/schemas/yadam/completed-artifact-incident.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reportType",
    "errorCode",
    "jobId",
    "incidentKeyHash",
    "firstObservedAt",
    "completedEvent",
    "expectedArtifacts",
    "observedArtifacts",
    "stateStatus",
    "mutationPolicy",
    "recovery",
    "completionOpaqueInputs"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "reportType": { "const": "completed_artifact_tampered" },
    "errorCode": { "const": "completed_artifact_tampered" },
    "jobId": { "type": "string" },
    "incidentKeyHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "firstObservedAt": { "type": "string" },
    "completedEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "inputHash", "outputHash", "artifactPaths"],
      "properties": {
        "stage": { "const": "FINAL_QA_PASSED" },
        "inputHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "outputHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "artifactPaths": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "expectedArtifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifactId", "logicalRole", "path", "expectedSha256"],
        "properties": {
          "artifactId": { "type": "string" },
          "logicalRole": { "type": "string" },
          "path": { "type": "string" },
          "expectedSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "observedArtifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifactId", "logicalRole", "path", "status", "expectedSha256", "observedSha256"],
        "properties": {
          "artifactId": { "type": "string" },
          "logicalRole": { "type": "string" },
          "path": { "type": "string" },
          "status": { "enum": ["missing", "hash_mismatch"] },
          "expectedSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "observedSha256": {
            "oneOf": [
              { "type": "null" },
              { "type": "string", "pattern": "^[0-9a-f]{64}$" }
            ]
          }
        }
      }
    },
    "stateStatus": { "const": "completed" },
    "mutationPolicy": { "const": "read_only_except_append_only_incident" },
    "recovery": { "const": "trusted_backup_or_new_job" },
    "completionOpaqueInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileHash", "ffmpegVersionHash", "assemblerPolicyHash", "qaPolicyHash"],
      "properties": {
        "profileHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "ffmpegVersionHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "assemblerPolicyHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "qaPolicyHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
