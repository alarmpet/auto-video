{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-video/schemas/yadam/render-plan-input.schema.json/v1",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "profileId": { "type": "string", "const": "yadam" },
    "jobId": { "type": "string" },
    "video": {
      "type": "object",
      "properties": {
        "width": { "type": "integer", "const": 1920 },
        "height": { "type": "integer", "const": 1080 },
        "fps": { "type": "integer", "const": 24 }
      },
      "required": ["width", "height", "fps"],
      "additionalProperties": false
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "approvalRevisionPath": { "type": "string" },
        "approvalRevisionHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "audioManifestPath": { "type": "string" },
        "audioManifestHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "audioTimelinePath": { "type": "string" },
        "audioTimelineHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "required": [
        "approvalRevisionPath",
        "approvalRevisionHash",
        "audioManifestPath",
        "audioManifestHash",
        "audioTimelinePath",
        "audioTimelineHash"
      ],
      "additionalProperties": false
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sceneId": { "type": "string" },
          "segmentId": { "type": "string" },
          "order": { "type": "integer", "minimum": 1 },
          "sourceHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "ttsNormalizedHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "ttsOptionsHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "normalizedWavPath": { "type": "string" },
          "normalizedWavHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "durationSeconds": { "type": "number", "exclusiveMinimum": 0 },
          "startSeconds": { "type": "number", "minimum": 0 },
          "endSeconds": { "type": "number", "exclusiveMinimum": 0 }
        },
        "required": [
          "sceneId", "segmentId", "order", "sourceHash", "ttsNormalizedHash", "ttsOptionsHash",
          "normalizedWavPath", "normalizedWavHash", "durationSeconds", "startSeconds", "endSeconds"
        ],
        "additionalProperties": false
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "segmentId": { "type": "string" },
          "plannedDurationSeconds": { "type": "integer", "const": 600 },
          "measuredAudioSeconds": { "type": "number", "exclusiveMinimum": 0 },
          "startSeconds": { "type": "number", "minimum": 0 },
          "endSeconds": { "type": "number", "exclusiveMinimum": 0 }
        },
        "required": ["segmentId", "plannedDurationSeconds", "measuredAudioSeconds", "startSeconds", "endSeconds"],
        "additionalProperties": false
      }
    },
    "visualSlots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "visualSlotId": { "type": "string" },
          "visualOrder": { "type": "integer", "minimum": 1 },
          "segmentId": { "type": "string" },
          "sourceSceneIds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string" }
          },
          "primarySceneId": { "type": "string" },
          "startSeconds": { "type": "number", "minimum": 0 },
          "endSeconds": { "type": "number", "exclusiveMinimum": 0 },
          "durationSeconds": { "type": "number", "exclusiveMinimum": 0 },
          "timingBand": { "type": "string", "enum": ["intro", "body"] },
          "extendedHold": { "type": "boolean" },
          "holdReason": { "type": ["string", "null"], "enum": ["cta", "short_tail", null] },
          "purpose": { "type": "string", "enum": ["intro", "scene"] }
        },
        "required": [
          "visualSlotId", "visualOrder", "segmentId", "sourceSceneIds", "primarySceneId",
          "startSeconds", "endSeconds", "durationSeconds", "timingBand", "extendedHold",
          "holdReason", "purpose"
        ],
        "additionalProperties": false,
        "not": {
          "anyOf": [
            { "required": ["imagePath"] },
            { "required": ["imageSha256"] },
            { "required": ["providerJobId"] },
            { "required": ["compiledRequestId"] }
          ]
        }
      }
    },
    "subtitleSources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sceneId": { "type": "string" },
          "sourceText": { "type": "string" },
          "sourceHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "startSeconds": { "type": "number", "minimum": 0 },
          "endSeconds": { "type": "number", "exclusiveMinimum": 0 }
        },
        "required": ["sceneId", "sourceText", "sourceHash", "startSeconds", "endSeconds"],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schemaVersion", "profileId", "jobId", "video", "dependencies",
    "scenes", "segments", "visualSlots", "subtitleSources"
  ],
  "additionalProperties": false
}
