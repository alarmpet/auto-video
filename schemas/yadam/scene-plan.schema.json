{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-video/schemas/yadam/scene-plan.schema.json/v1",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "jobId": { "type": "string" },
    "stageId": { "type": "string" },
    "inputHash": { "type": "string" },
    "scenePlans": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sceneId": { "type": "string", "pattern": "^scene-[0-9]{4}$" },
          "slots": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "slotId": { "type": "string" },
                "narrativeText": { "type": "string" },
                "visualPrompt": { "type": "string" }
              },
              "required": ["slotId", "narrativeText", "visualPrompt"],
              "additionalProperties": false
            }
          }
        },
        "required": ["sceneId", "slots"],
        "additionalProperties": false
      }
    }
  },
  "required": ["schemaVersion", "jobId", "stageId", "inputHash", "scenePlans"],
  "additionalProperties": false
}
